import React, { useEffect, useMemo, useState } from "react";
import { useParams, useLocation } from "react-router-dom";

function fmtPct(v) {
  if (v === null || v === undefined) return "-";
  const n = Number(v);
  if (!Number.isFinite(n)) return "-";
  return `${n.toFixed(2)}%`;
}

function fmtDate(iso) {
  if (!iso) return "-";
  try {
    return new Intl.DateTimeFormat("pt-BR", {
      dateStyle: "short",
      timeStyle: "medium",
      timeZone: "America/Sao_Paulo",
    }).format(new Date(iso));
  } catch {
    return iso;
  }
}

export default function Customer() {
  const params = useParams();
  const location = useLocation();

  // ✅ sua rota é /tenant/:tenantID (D maiúsculo)
  const tenantId =
    params.tenantID ||
    params.tenantId ||
    params.id ||
    (location.pathname.split("/").pop() || "");

  const [loading, setLoading] = useState(true);
  const [summary, setSummary] = useState(null);
  const [hosts, setHosts] = useState([]);
  const [selectedHost, setSelectedHost] = useState("");
  const [window, setWindow] = useState("24h");
  const [seriesMetric, setSeriesMetric] = useState("cpu_percent");
  const [series, setSeries] = useState([]);
  const [errorMsg, setErrorMsg] = useState("");

  const selected = useMemo(
    () => hosts.find((h) => h.hostname === selectedHost) || null,
    [hosts, selectedHost]
  );

  async function loadAll() {
    if (!tenantId) {
      setErrorMsg("Tenant ID não encontrado na URL (/tenant/:tenantID).");
      setLoading(false);
      return;
    }

    setLoading(true);
    setErrorMsg("");

    try {
      const [sRes, hRes] = await Promise.all([
        fetch(`/api/v1/tenants/${tenantId}/dashboard/summary`, { credentials: "include" }),
        fetch(`/api/v1/tenants/${tenantId}/dashboard/hosts`, { credentials: "include" }),
      ]);

      if (!sRes.ok) throw new Error(`summary HTTP ${sRes.status}`);
      if (!hRes.ok) throw new Error(`hosts HTTP ${hRes.status}`);

      const s = await sRes.json();
      const h = await hRes.json();

      setSummary(s);
      setHosts(Array.isArray(h) ? h : []);

      const pick =
        (Array.isArray(h) && h.find((x) => x.status === "ONLINE")?.hostname) ||
        (Array.isArray(h) && h[0]?.hostname) ||
        "";
      setSelectedHost((prev) => prev || pick);
    } catch (e) {
      console.error("Erro ao carregar dashboard:", e);
      setSummary(null);
      setHosts([]);
      setSelectedHost("");
      setErrorMsg(String(e?.message || e));
    } finally {
      setLoading(false);
    }
  }

  async function loadSeries(hostname, metricName, win) {
    if (!tenantId || !hostname || !metricName) return;
    try {
      const res = await fetch(
        `/api/v1/tenants/${tenantId}/dashboard/series?hostname=${encodeURIComponent(hostname)}&metric=${encodeURIComponent(metricName)}&window=${encodeURIComponent(win)}`,
        { credentials: "include" }
      );
      if (!res.ok) throw new Error(`series HTTP ${res.status}`);
      const data = await res.json();
      setSeries(Array.isArray(data?.points) ? data.points : []);
    } catch (e) {
      console.error("Erro ao carregar série:", e);
      setSeries([]);
    }
  }

  useEffect(() => { loadAll(); /* eslint-disable-next-line */ }, [tenantId]);
  useEffect(() => { if (selectedHost) loadSeries(selectedHost, seriesMetric, window); /* eslint-disable-next-line */ }, [selectedHost, seriesMetric, window, tenantId]);

  return (
    <div className="p-6 space-y-4">
      <div className="flex items-start justify-between gap-4">
        <div>
          <h1 className="text-2xl font-bold">Dashboard do Cliente</h1>
          <div className="text-sm text-slate-400 mt-1">
            Tenant: <span className="font-mono text-slate-300">{tenantId || "(vazio)"}</span>
          </div>
          {errorMsg && (
            <div className="mt-3 rounded-lg border border-rose-500/40 bg-rose-500/10 p-3 text-sm text-rose-200">
              <b>Erro:</b> {errorMsg}
            </div>
          )}
        </div>

        <button
          onClick={loadAll}
          className="px-4 py-2 rounded bg-sky-600 hover:bg-sky-500 font-semibold"
        >
          Atualizar
        </button>
      </div>

      {/* Cards */}
      <div className="grid grid-cols-1 md:grid-cols-4 gap-3">
        <Card title="Hosts" value={summary?.total_hosts ?? "-"} loading={loading} />
        <Card title="Online" value={summary?.online ?? "-"} loading={loading} />
        <Card title="Offline" value={summary?.offline ?? "-"} loading={loading} />
        <Card title="Último heartbeat" value={fmtDate(summary?.last_any_heartbeat)} loading={loading} />
      </div>


      {/* Downloads */}
      <div className="rounded-xl border border-slate-800 bg-slate-950/50 p-4">
        <div className="flex items-center justify-between gap-3">
          <div>
            <div className="text-sm font-bold text-slate-100">Downloads de Agentes</div>
            <div className="text-xs text-slate-400">Instale o agente no Windows ou Linux para começar a coletar métricas.</div>
          </div>
        </div>

        <div className="mt-3 grid grid-cols-1 md:grid-cols-3 gap-3">
          <a
            className="rounded-lg border border-slate-800 bg-slate-900/40 hover:bg-slate-900/60 p-3"
            href="/downloads/nocguardian-agent.msi"
          >
            <div className="font-semibold text-slate-100">Windows (MSI)</div>
            <div className="text-xs text-slate-400">nocguardian-agent.msi</div>
          </a>

          <a
            className="rounded-lg border border-slate-800 bg-slate-900/40 hover:bg-slate-900/60 p-3"
            href="/downloads/nocguardian-agent_arm64.deb"
          >
            <div className="font-semibold text-slate-100">Linux ARM64 (.deb)</div>
            <div className="text-xs text-slate-400">nocguardian-agent_arm64.deb</div>
          </a>

          <a
            className="rounded-lg border border-slate-800 bg-slate-900/40 hover:bg-slate-900/60 p-3"
            href="/downloads/nocguardian-agent_amd64.deb"
          >
            <div className="font-semibold text-slate-100">Linux AMD64 (.deb)</div>
            <div className="text-xs text-slate-400">nocguardian-agent_amd64.deb</div>
          </a>
        </div>

        <div className="mt-3 text-xs text-slate-500">
          Se algum link retornar 404, confirme o nome do arquivo em <span className="font-mono">/opt/noc-guardian/downloads</span>.
        </div>
      </div>


      {/* Conteúdo */}
      <div className="grid grid-cols-1 xl:grid-cols-2 gap-3">
        {/* Hosts */}
        <div className="rounded-xl border border-slate-800 bg-slate-950/50 overflow-hidden">
          <div className="px-4 py-3 border-b border-slate-800 font-semibold text-slate-100">
            Hosts
          </div>

          <div className="overflow-x-auto">
            <table className="w-full text-sm">
              <thead className="text-slate-400">
                <tr>
                  <th className="text-left px-4 py-3">Hostname</th>
                  <th className="text-left px-4 py-3">Status</th>
                  <th className="text-left px-4 py-3">CPU</th>
                  <th className="text-left px-4 py-3">Mem</th>
                  <th className="text-left px-4 py-3">Disco</th>
                  <th className="text-left px-4 py-3">Último</th>
                </tr>
              </thead>
              <tbody>
                {hosts.map((h) => {
                  const active = h.hostname === selectedHost;
                  return (
                    <tr
                      key={h.hostname}
                      onClick={() => setSelectedHost(h.hostname)}
                      className={`border-t border-slate-800 cursor-pointer ${active ? "bg-sky-500/10" : "hover:bg-slate-900/50"}`}
                    >
                      <td className="px-4 py-3 font-semibold text-slate-100">{h.hostname}</td>
                      <td className="px-4 py-3"><Badge status={h.status} /></td>
                      <td className="px-4 py-3 text-slate-200">{fmtPct(h.cpu_percent)}</td>
                      <td className="px-4 py-3 text-slate-200">{fmtPct(h.mem_used_pct)}</td>
                      <td className="px-4 py-3 text-slate-200">{fmtPct(h.disk_used_pct)}</td>
                      <td className="px-4 py-3 text-slate-400">{fmtDate(h.last_seen)}</td>
                    </tr>
                  );
                })}

                {!loading && hosts.length === 0 && (
                  <tr>
                    <td colSpan={6} className="px-4 py-6 text-slate-500">
                      Nenhum host encontrado neste tenant.
                    </td>
                  </tr>
                )}
              </tbody>
            </table>
          </div>
        </div>

        {/* Detalhes */}
        <div className="rounded-xl border border-slate-800 bg-slate-950/50 overflow-hidden">
          <div className="px-4 py-3 border-b border-slate-800 font-semibold text-slate-100">
            Detalhes
          </div>

          <div className="p-4 space-y-3">
            {!selected && (
              <div className="text-slate-400">
                Selecione um host à esquerda para ver detalhes.
              </div>
            )}

            {selected && (
              <>
                <KV k="Hostname" v={selected.hostname} />
                <KV k="OS" v={selected.os || "-"} />
                <KV k="Agent ID" v={selected.agent_id || "-"} mono />
                <KV k="Status" v={<Badge status={selected.status} />} />
                <KV k="Último heartbeat" v={fmtDate(selected.last_seen)} />

                <div className="pt-2 grid grid-cols-1 sm:grid-cols-2 gap-3">
                  <Select
                    label="Janela"
                    value={window}
                    onChange={setWindow}
                    options={[
                      { value: "1h", label: "1 hora" },
                      { value: "24h", label: "24 horas" },
                    ]}
                  />
                  <Select
                    label="Métrica"
                    value={seriesMetric}
                    onChange={setSeriesMetric}
                    options={[
                      { value: "cpu_percent", label: "CPU (%)" },
                      { value: "mem_used_pct", label: "Memória (%)" },
                      { value: "disk_used_pct", label: "Disco (%)" },
                    ]}
                  />
                </div>

                <SeriesMiniChart points={series} />
              </>
            )}
          </div>
        </div>
      </div>
    </div>
  );
}

function Card({ title, value, loading }) {
  return (
    <div className="rounded-xl border border-slate-800 bg-slate-950/50 p-4">
      <div className="text-xs text-slate-400 font-semibold">{title}</div>
      <div className="text-xl font-extrabold text-slate-100 mt-1">
        {loading ? "..." : value}
      </div>
    </div>
  );
}

function Badge({ status }) {
  const ok = status === "ONLINE";
  return (
    <span className={`inline-flex items-center px-3 py-1 rounded-full text-xs font-bold border
      ${ok ? "bg-emerald-500/15 text-emerald-200 border-emerald-500/30" : "bg-amber-500/15 text-amber-200 border-amber-500/30"}`}>
      {status || "-"}
    </span>
  );
}

function KV({ k, v, mono }) {
  return (
    <div className="flex items-center justify-between gap-3">
      <div className="text-xs text-slate-400 font-semibold">{k}</div>
      <div className={`text-sm text-slate-100 font-semibold ${mono ? "font-mono" : ""}`}>
        {v}
      </div>
    </div>
  );
}

function Select({ label, value, onChange, options }) {
  return (
    <label className="grid gap-1">
      <div className="text-xs text-slate-400 font-semibold">{label}</div>
      <select
        value={value}
        onChange={(e) => onChange(e.target.value)}
        className="w-full rounded-lg border border-slate-800 bg-slate-900/60 text-slate-100 px-3 py-2 font-semibold"
      >
        {options.map((o) => (
          <option key={o.value} value={o.value}>{o.label}</option>
        ))}
      </select>
    </label>
  );
}

function SeriesMiniChart({ points }) {
  const data = Array.isArray(points) ? points.slice(-60) : [];
  const values = data.map((p) => Number(p.v)).filter((v) => Number.isFinite(v));
  const max = values.length ? Math.max(...values) : 1;

  return (
    <div className="pt-2">
      <div className="text-xs text-slate-400 font-semibold mb-2">Série (últimos pontos)</div>
      <div className="h-28 rounded-xl border border-slate-800 bg-slate-900/40 p-3 flex items-end gap-[2px] overflow-hidden">
        {data.length === 0 && <div className="text-slate-500 text-sm">Sem dados para plotar.</div>}
        {data.map((p, i) => {
          const v = Number(p.v);
          const h = Number.isFinite(v) ? Math.max(2, Math.round((v / max) * 90)) : 2;
          return (
            <div
              key={i}
              title={`${p.t} = ${v}`}
              style={{ height: h, width: 4 }}
              className="rounded bg-sky-500/70"
            />
          );
        })}
      </div>
      {data.length > 0 && (
        <div className="mt-2 text-xs text-slate-400">
          Último: <span className="text-slate-200 font-semibold">{data[data.length - 1]?.v}</span>{" "}
          em <span className="text-slate-200 font-semibold">{fmtDate(data[data.length - 1]?.t)}</span>
        </div>
      )}
    </div>
  );
}
