<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi"
     xmlns:util="http://schemas.microsoft.com/wix/UtilExtension">

  <Product Id="*" Name="NOC Guardian Agent" Language="1046" Codepage="65001" Version="0.1.7" Manufacturer="BitByteTI" UpgradeCode="5d728440-cd20-4cee-8874-6d53724ca35f">
    <Package InstallerVersion="500" Compressed="yes" InstallScope="perMachine" />

    <MajorUpgrade DowngradeErrorMessage="Uma versão mais nova já está instalada." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Propriedades passadas no msiexec -->
    <Property Id="SERVER_URL" Value="https://nocguardian.bitbyteti.tec.br" />
    <Property Id="TENANT_ID" Secure="yes" />
    <Condition Message="TENANT_ID is required. Example: msiexec /i nocguardian-agent-windows-x64.msi TENANT_ID={UUID} SERVER_URL=https://... /qn">
      TENANT_ID &lt;&gt; ""
    </Condition>

    <!-- Caminhos -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="NOCGuardian">
          <Directory Id="AGENTDIR" Name="Agent" />
        </Directory>
      </Directory>

      <Directory Id="CommonAppDataFolder">
        <Directory Id="NGDATA" Name="NOCGuardian">
          <Directory Id="NGAGENTDATA" Name="Agent" />
        </Directory>
      </Directory>
    </Directory>

    <Feature Id="ProductFeature" Title="NOC Guardian Agent" Level="1">
      <ComponentGroupRef Id="AgentComponents" />
    </Feature>

  </Product>

  <Fragment>
    <ComponentGroup Id="AgentComponents" Directory="AGENTDIR">

      <Component Id="AgentExeAndService" Guid="6dd714fd-4bae-4101-b6f3-4d1f5316b834">

        <File Id="AgentBinary" Source="..\..\dist\windows_amd64\nocguardian-agent.exe" KeyPath="yes" />

        <!-- Serviço Windows -->
        <ServiceInstall
          Id="SvcInstall"
          Name="NOCGuardianAgent"
          DisplayName="NOC Guardian Agent"
          Description="NOC Guardian Agent Service"
          Type="ownProcess"
          Start="auto"
          ErrorControl="normal"
          Account="LocalSystem"
          Vital="yes"
          Interactive="no"
          Arguments="--config &quot;[NGAGENTDATA]agent.yml&quot; --server-url &quot;[SERVER_URL]&quot; --tenant-id &quot;[TENANT_ID]&quot; --interval 30 --disk C:\\" />

        <ServiceControl
          Id="SvcControl"
          Name="NOCGuardianAgent"
          Stop="both"
          Remove="uninstall"
          Wait="yes" />

        <!-- Recovery (opcional) -->
        <util:ServiceConfig
          ServiceName="NOCGuardianAgent"
          FirstFailureActionType="restart"
          SecondFailureActionType="restart"
          ThirdFailureActionType="restart"
          ResetPeriodInDays="1" />

      </Component>

    </ComponentGroup>
  </Fragment>

</Wix>
